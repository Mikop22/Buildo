# Meshy API Configuration
# 
# Instructions:
# 1. Copy this file to .env.local
# 2. Replace 'your_meshy_api_key_here' with your actual Meshy API key
# 3. Never commit .env.local to git (it's already in .gitignore)
#
# Get your API key from: https://meshy.ai (or your Meshy dashboard)

VITE_MESHY_API_KEY=your_meshy_api_key_here
